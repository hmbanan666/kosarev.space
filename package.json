{
  "name": "@kosarev/space-monorepo",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=24.14.0",
    "pnpm": ">=10.32.1"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "typecheck": "pnpm -r run typecheck",
    "check:full": "pnpm run lint:fix && pnpm run typecheck && pnpm vitest run",
    "prepare": "husky"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:dev",
    "@commitlint/cli": "catalog:dev",
    "@commitlint/config-conventional": "catalog:dev",
    "@vitest/coverage-v8": "catalog:test",
    "bumpp": "catalog:dev",
    "eslint": "catalog:dev",
    "husky": "catalog:dev",
    "nano-staged": "catalog:dev",
    "typescript": "catalog:dev",
    "vite": "catalog:dev",
    "vitest": "catalog:test",
    "vue-tsc": "catalog:dev"
  },
  "nano-staged": {
    "*.{js,ts,tsx,vue,json}": [
      "eslint --cache --fix"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  }
}
